# Copy to .env on the Pi and fill in. See DEPLOYMENT.md §3.
PARTYSNAP_DOMAIN=snap.example.com
APP_PORT=8080                 # REQUIRED — the HOST port nginx proxies to; any free port (container is always 8000 internally)
# Master secret: signs sessions AND encrypts the Google refresh token at rest.
# Durable — rotating it logs everyone out and orphans the stored token. 32+ bytes, base64.
APP_SECRET=change-me-32-random-bytes-base64

# Database (container-internal, localhost-bound)
POSTGRES_USER=partysnap
POSTGRES_PASSWORD=change-me
POSTGRES_DB=partysnap

# Admin bootstrap (env-seeded; cleared after first login — DEPLOYMENT §5)
ADMIN_HANDLE=martial
ADMIN_PASSWORD=change-me-once

# Convenience mode (OPTIONAL; omit for privacy-only — DEPLOYMENT §7).
# The OAuth redirect URI is derived from PARTYSNAP_DOMAIN — register
# https://<PARTYSNAP_DOMAIN>/api/admin/google/oauth/callback on the Cloud Console client.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
